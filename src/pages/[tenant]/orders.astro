---
import Layout from '../../layouts/Layout.astro';
import { eq, desc } from 'drizzle-orm';
import * as schema from '../../db/schema';
import { formatCurrency, cn } from '../../lib/utils';

const { tenant, db, session } = Astro.locals;
const { tenant: tenantSlug } = Astro.params;

if (!tenant) return Astro.redirect('/login');

const orders = await db.select({
  id: schema.transactions.id,
  invoiceNumber: schema.transactions.invoiceNumber,
  subtotal: schema.transactions.subtotal,
  total: schema.transactions.total,
  status: schema.transactions.status,
  createdAt: schema.transactions.createdAt,
  cashierName: schema.users.name,
})
.from(schema.transactions)
.leftJoin(schema.users, eq(schema.transactions.cashierId, schema.users.id))
.where(eq(schema.transactions.tenantId, tenant.id))
.orderBy(desc(schema.transactions.createdAt))
.limit(50);

const isAdmin = session?.role === 'tenant_admin' || session?.role === 'super_admin';
---

<Layout title={`Order History - ${tenant.name}`}>
  <main class="flex-1 bg-slate-50 min-h-screen">
    <header class="h-20 bg-white border-b flex items-center justify-between px-4 sm:px-8 sticky top-0 z-10">
      <div class="flex items-center gap-2 sm:gap-4">
        <h1 class="font-black text-xl sm:text-2xl uppercase tracking-tighter">Order History</h1>
        <div class="h-6 w-px bg-slate-200 hidden sm:block"></div>
        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest hidden sm:block">Transaction Records</p>
      </div>
      <div class="flex items-center gap-3">
        <div class="text-[10px] font-black text-slate-400 uppercase tracking-widest bg-slate-100 px-3 sm:px-4 py-2 rounded-lg border border-slate-200">
            Real-time Sync
        </div>
      </div>
    </header>

    <div class="p-4 sm:p-8 md:p-12 max-w-7xl mx-auto space-y-8 sm:space-y-12">
      <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-sm overflow-x-auto no-scrollbar animate-in fade-in slide-in-from-bottom-4 duration-700">
        <table class="w-full text-sm">
          <thead class="bg-slate-50/50 border-b border-slate-100">
            <tr>
              <th class="p-6 text-left font-black text-slate-500 uppercase tracking-widest text-[10px]">Invoice</th>
              <th class="p-6 text-left font-black text-slate-500 uppercase tracking-widest text-[10px] hidden sm:table-cell">Date</th>
              <th class="p-6 text-left font-black text-slate-500 uppercase tracking-widest text-[10px] hidden md:table-cell">Cashier</th>
              <th class="p-6 text-left font-black text-slate-500 uppercase tracking-widest text-[10px]">Amount</th>
              <th class="p-6 text-left font-black text-slate-500 uppercase tracking-widest text-[10px]">Status</th>
              <th class="p-6 text-right font-black text-slate-500 uppercase tracking-widest text-[10px]">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-50">
            {orders.length > 0 ? orders.map((order: any) => (
              <tr class="hover:bg-slate-50/50 transition-colors group">
                <td class="p-6">
                  <span class="font-black text-indigo-600 font-mono tracking-tighter text-lg">{order.invoiceNumber}</span>
                </td>
                <td class="p-6 hidden sm:table-cell">
                  <p class="font-bold text-slate-900">{order.createdAt.toLocaleDateString('en-US', { day: 'numeric', month: 'short' })}</p>
                  <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">{order.createdAt.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</p>
                </td>
                <td class="p-6 hidden md:table-cell">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-slate-100 flex items-center justify-center font-bold text-slate-400 uppercase shadow-inner group-hover:bg-indigo-100 group-hover:text-indigo-600 transition-colors">
                      {order.cashierName?.charAt(0)}
                    </div>
                    <span class="font-bold text-slate-700">{order.cashierName}</span>
                  </div>
                </td>
                <td class="p-6">
                  <span class="font-black text-lg text-slate-900 tabular-nums">{formatCurrency(order.total)}</span>
                </td>
                <td class="p-6">
                  <span class={cn(
                    "px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border",
                    order.status === 'completed' ? "bg-green-50 text-green-700 border-green-100" : "bg-red-50 text-red-700 border-red-100"
                  )}>
                    {order.status}
                  </span>
                </td>
                <td class="p-6 text-right">
                    <button 
                         onclick={`viewDetails('${order.id}')`}
                         class="bg-slate-900 text-white px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-indigo-600 transition-all shadow-lg active:scale-95"
                    >
                        Details
                    </button>
                </td>
              </tr>
            )) : (
              <tr>
                <td colspan="6" class="p-20 text-center text-slate-300 font-black italic uppercase tracking-widest opacity-40">
                  No orders recorded yet
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Order Details Modal -->
    <div id="details-modal" class="fixed inset-0 z-50 hidden">
        <div class="absolute inset-0 bg-slate-950/40 backdrop-blur-sm"></div>
        <div class="absolute inset-y-0 right-0 w-full max-w-2xl bg-white shadow-2xl flex flex-col transform transition-transform duration-500 translate-x-full" id="details-content">
          <div class="p-6 sm:p-8 md:p-12 border-b border-slate-100 flex items-center justify-between shrink-0">
            <div>
                <h2 id="modal-invoice" class="text-2xl sm:text-3xl font-black text-slate-900 uppercase tracking-tighter italic">INV-LOADING</h2>
                <p id="modal-date" class="text-slate-400 font-bold text-[10px] sm:text-xs uppercase tracking-widest mt-1">October 24, 2023 • 14:20</p>
            </div>
            <button id="close-modal" class="p-2 sm:p-3 hover:bg-slate-100 rounded-2xl transition-colors font-black text-lg">✕</button>
          </div>

          <div class="flex-1 overflow-y-auto p-4 sm:p-8 md:p-12 space-y-8 sm:space-y-12 no-scrollbar">
            <!-- Items Section -->
            <section class="space-y-4 sm:space-y-6">
                <h3 class="text-[10px] font-black text-indigo-600 uppercase tracking-[0.3em]">Purchased Items</h3>
                <div id="modal-items" class="space-y-3">
                    <!-- Items injected here -->
                </div>
            </section>

            <!-- Detailed Totals -->
            <section class="bg-slate-50 p-6 sm:p-8 rounded-[2rem] sm:rounded-[2.5rem] space-y-4">
                <div class="flex justify-between text-xs font-bold text-slate-400 uppercase tracking-widest">
                    <span>Subtotal</span>
                    <span id="modal-subtotal">-</span>
                </div>
                <div class="flex justify-between text-xs font-bold text-slate-400 uppercase tracking-widest">
                    <span>Tax (10%)</span>
                    <span id="modal-tax">-</span>
                </div>
                <div class="flex justify-between items-end pt-4 border-t border-slate-200">
                    <span class="font-black text-slate-900 uppercase text-xs sm:text-sm tracking-widest">Grand Total</span>
                    <span id="modal-total" class="text-2xl sm:text-3xl font-black text-slate-900 tracking-tighter">-</span>
                </div>
            </section>

            <!-- Audit History -->
            <section class="space-y-4 sm:space-y-6">
                <h3 class="text-[10px] font-black text-indigo-600 uppercase tracking-[0.3em]">Audit Trail & History</h3>
                <div id="modal-logs" class="space-y-6 border-l-2 border-slate-100 ml-3 pl-6 sm:pl-8">
                    <!-- Logs injected here -->
                </div>
            </section>
          </div>

          <div class="p-6 sm:p-8 md:p-12 bg-white border-t border-slate-100 flex flex-wrap gap-4 shrink-0">
             <button id="modal-print" class="flex-1 min-w-[140px] h-14 bg-slate-100 text-slate-900 rounded-2xl font-black uppercase tracking-widest text-[10px] hover:bg-slate-200 transition-all flex items-center justify-center gap-2">
                🖨️ Print Receipt
             </button>
             {isAdmin && (
                <button id="modal-cancel" class="flex-1 min-w-[140px] h-14 bg-red-50 text-red-600 rounded-2xl font-black uppercase tracking-widest text-[10px] hover:bg-red-600 hover:text-white transition-all">
                    🚫 Cancel Order
                </button>
             )}
          </div>
        </div>
      </div>
  </main>
</Layout>

<script is:inline>
  const modal = document.getElementById('details-modal');
  const detailsContent = document.getElementById('details-content');
  const closeBtn = document.getElementById('close-modal');
  let currentOrderId = '';

  function closeModal() {
    detailsContent.classList.remove('translate-x-0');
    detailsContent.classList.add('translate-x-full');
    setTimeout(() => modal.classList.add('hidden'), 500);
  }

  closeBtn?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal.children[0]) closeModal();
  });

  window.viewDetails = async (id) => {
    currentOrderId = id;
    modal.classList.remove('hidden');
    setTimeout(() => {
        detailsContent.classList.remove('translate-x-full');
        detailsContent.classList.add('translate-x-0');
    }, 10);

    const res = await fetch(`/api/transactions/${id}`);
    const data = await res.json();

    if (res.ok) {
        document.getElementById('modal-invoice').textContent = data.invoiceNumber;
        document.getElementById('modal-date').textContent = new Date(data.createdAt).toLocaleString();
        document.getElementById('modal-subtotal').textContent = formatCurrency(data.subtotal);
        document.getElementById('modal-tax').textContent = formatCurrency(data.subtotal * 0.1);
        document.getElementById('modal-total').textContent = formatCurrency(data.total);

        // Render Items
        document.getElementById('modal-items').innerHTML = data.items.map(item => `
            <div class="flex items-center justify-between bg-white p-5 rounded-2xl border border-slate-100 shadow-sm">
                <div>
                    <p class="font-black text-slate-900">${item.nameSnapshot}</p>
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">${item.qty} x ${formatCurrency(item.price)}</p>
                </div>
                <span class="font-black text-slate-800">${formatCurrency(item.total)}</span>
            </div>
        `).join('');

        // Render Logs
        document.getElementById('modal-logs').innerHTML = data.logs.map(log => `
            <div class="relative">
                <div class="absolute -left-[41px] top-1 w-4 h-4 rounded-full border-4 border-white bg-indigo-500 shadow-sm"></div>
                <div>
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">${new Date(log.createdAt).toLocaleString()}</p>
                    <p class="font-bold text-slate-900">${log.action.toUpperCase()}</p>
                    <p class="text-xs text-slate-500 italic mt-1">Processed by ${log.userName}</p>
                    ${log.details ? `<p class="mt-2 text-[10px] bg-slate-50 p-2 rounded-lg border border-slate-100 text-slate-400 font-mono">${log.details}</p>` : ''}
                </div>
            </div>
        `).join('') || '<p class="text-slate-300 italic text-xs">No audit logs available</p>';

        // Setup Cancel Button
        const cancelBtn = document.getElementById('modal-cancel');
        if (cancelBtn) {
            cancelBtn.classList.toggle('hidden', data.status === 'cancelled');
            cancelBtn.onclick = async () => {
                const reason = prompt('Enter cancellation reason:');
                if (reason === null) return;
                
                const patchRes = await fetch(`/api/transactions/${id}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: 'cancel', notes: reason })
                });

                if (patchRes.ok) window.location.reload();
                else alert('Cancellation failed');
            };
        }

        // Setup Print Button
        const printBtn = document.getElementById('modal-print');
        printBtn.onclick = () => {
            window.open(`/${window.location.pathname.split('/')[1]}/receipt/${id}`, '_blank');
        };

    } else {
        alert('Could not load details');
        closeModal();
    }
  };

  function formatCurrency(val) {
    return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(val);
  }
</script>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
</style>
