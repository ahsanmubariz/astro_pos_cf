---
import Layout from '../../layouts/Layout.astro';
import { eq, and, sql, desc } from 'drizzle-orm';
import * as schema from '../../db/schema';
import { cn } from '../../lib/utils';
import { formatCurrency } from '../../lib/utils';

const { tenant, db } = Astro.locals;
const { tenant: tenantSlug } = Astro.params;

if (!tenant) return Astro.redirect('/login');

// Daily stats
const today = new Date();
today.setHours(0, 0, 0, 0);

const stats = await db.select({
  totalSales: sql`sum(${schema.transactions.total})`,
  txCount: sql`count(*)`,
  avgTransaction: sql`avg(${schema.transactions.total})`
})
.from(schema.transactions)
.where(and(
  eq(schema.transactions.tenantId, tenant.id),
  sql`created_at >= ${today.getTime()}`
));

const dailyOmzet = Number(stats[0].totalSales) || 0;
const txCount = Number(stats[0].txCount) || 0;
const avgTx = Number(stats[0].avgTransaction) || 0;

// Best Sellers
const bestSellers = await db.select({
  name: schema.transactionItems.nameSnapshot,
  totalQty: sql`sum(${schema.transactionItems.qty})`,
  totalRevenue: sql`sum(${schema.transactionItems.total})`
})
.from(schema.transactionItems)
.innerJoin(schema.transactions, eq(schema.transactionItems.transactionId, schema.transactions.id))
.where(eq(schema.transactions.tenantId, tenant.id))
.groupBy(schema.transactionItems.nameSnapshot)
.orderBy(desc(sql`sum(${schema.transactionItems.qty})`))
.limit(5);
---

<Layout title={`Dashboard - ${tenant.name}`}>
  <main class="flex-1">
    <header class="h-16 bg-white border-b flex items-center justify-between px-8 sticky top-0 z-10">
      <h1 class="font-bold text-xl uppercase tracking-tighter">Business Overview</h1>
      <div class="flex items-center gap-4">
        <span class="text-xs font-black text-slate-400 bg-slate-100 px-3 py-1 rounded-full uppercase tracking-widest">{new Date().toLocaleDateString('en-US', { dateStyle: 'medium' })}</span>
      </div>
    </header>

    <div class="p-12 max-w-7xl mx-auto space-y-12">
      <!-- Stats Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-100 group hover:shadow-xl transition-all duration-500">
          <span class="text-[10px] font-black text-indigo-600 uppercase tracking-widest">Daily Omzet</span>
          <div class="flex items-end gap-3 mt-4">
            <span class="text-4xl font-black text-slate-900 tracking-tighter">{formatCurrency(dailyOmzet)}</span>
            <div class="flex items-center gap-1 bg-green-50 px-2 py-1 rounded-lg mb-1.5 border border-green-100">
               <span class="text-[10px] text-green-600 font-black">+12%</span>
            </div>
          </div>
        </div>
        
        <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-100 group hover:shadow-xl transition-all duration-500">
          <span class="text-[10px] font-black text-blue-600 uppercase tracking-widest">Total Orders</span>
          <div class="flex items-end gap-3 mt-4">
            <span class="text-4xl font-black text-slate-900 tracking-tighter">{txCount}</span>
            <span class="text-[10px] text-slate-400 font-bold mb-1.5 uppercase">Transactions</span>
          </div>
        </div>

        <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-100 group hover:shadow-xl transition-all duration-500">
          <span class="text-[10px] font-black text-rose-600 uppercase tracking-widest">Average Basket</span>
          <div class="flex items-end gap-3 mt-4">
            <span class="text-4xl font-black text-slate-900 tracking-tighter">{formatCurrency(avgTx)}</span>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Best Sellers -->
        <div class="bg-white rounded-[2.5rem] shadow-sm border border-slate-100 overflow-hidden">
          <div class="p-8 border-b border-slate-50 flex items-center justify-between">
            <h2 class="font-black text-xl uppercase tracking-tighter">🏆 Best Sellers</h2>
          </div>
          <div class="divide-y divide-slate-50">
            {bestSellers.length > 0 ? bestSellers.map((item: any) => (
              <div class="p-6 flex items-center justify-between group hover:bg-slate-50/50 transition-colors">
                <div class="flex items-center gap-5">
                  <div class="w-14 h-14 bg-slate-100 rounded-2xl flex items-center justify-center font-black text-slate-900 text-xl shadow-inner group-hover:scale-105 transition-transform uppercase italic">
                    {item.name?.charAt(0)}
                  </div>
                  <div>
                    <p class="font-black text-slate-900 text-lg">{item.name}</p>
                    <p class="text-xs text-slate-400 font-bold uppercase tracking-widest">{item.totalQty} Units Sold</p>
                  </div>
                </div>
                <div class="text-right">
                  <span class="font-black text-lg text-indigo-600">{formatCurrency(item.totalRevenue)}</span>
                </div>
              </div>
            )) : (
              <div class="p-12 text-center text-slate-400 font-bold italic">No sales recorded yet</div>
            )}
          </div>
        </div>

        <!-- Quick Actions -->
        <div class="bg-slate-900 rounded-[3rem] shadow-2xl p-12 text-white flex flex-col justify-between overflow-hidden relative">
          <div class="absolute top-[-50px] right-[-50px] w-64 h-64 bg-indigo-600 rounded-full blur-[100px] opacity-20"></div>
          
          <div class="relative">
            <h2 class="font-black text-3xl uppercase tracking-tighter mb-2">Terminal</h2>
            <p class="text-slate-400 font-bold text-sm">Quick navigation for store operations</p>
          </div>
          
          <div class="grid grid-cols-2 gap-6 relative mt-12">
            <a href={`/${tenantSlug}/pos`} class="p-8 bg-white/5 hover:bg-white/10 rounded-3xl border border-white/10 transition-all group">
              <span class="block text-3xl mb-3 group-hover:scale-110 transition-transform">🖥️</span>
              <span class="text-sm font-black uppercase tracking-widest">Point of Sale</span>
            </a>
            <a href={`/${tenantSlug}/shift`} class="p-8 bg-white/5 hover:bg-white/10 rounded-3xl border border-white/10 transition-all group">
              <span class="block text-3xl mb-3 group-hover:scale-110 transition-transform">💰</span>
              <span class="text-sm font-black uppercase tracking-widest">Shifts</span>
            </a>
            <a href={`/${tenantSlug}/admin/products`} class="p-8 bg-white/5 hover:bg-white/10 rounded-3xl border border-white/10 transition-all group">
              <span class="block text-3xl mb-3 group-hover:scale-110 transition-transform">📦</span>
              <span class="text-sm font-black uppercase tracking-widest">Inventory</span>
            </a>
            <a href={`/api/reports/transactions.csv`} class="p-8 bg-white/5 hover:bg-white/10 rounded-3xl border border-white/10 transition-all group">
              <span class="block text-3xl mb-3 group-hover:scale-110 transition-transform">📉</span>
              <span class="text-sm font-black uppercase tracking-widest">Report</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
