---
import Layout from '../../../layouts/Layout.astro';
import { eq, desc } from 'drizzle-orm';
import * as schema from '../../../db/schema';
import { cn, formatCurrency } from '../../../lib/utils';

const { tenant, db, session } = Astro.locals;
const { tenant: tenantSlug } = Astro.params;

if (!tenant) return Astro.redirect('/login');

// Security: Only tenant_admin or super_admin
if (!session || (session.role !== 'tenant_admin' && session.role !== 'super_admin')) {
  return Astro.redirect('/login');
}

const products = await db.select()
  .from(schema.products)
  .where(eq(schema.products.tenantId, tenant.id))
  .orderBy(desc(schema.products.createdAt));

const categories = [...new Set(products.map((p: any) => p.category))];
---

<Layout title={`Product Inventory - ${tenant.name}`}>
  <main class="flex-1 bg-slate-50 min-h-screen">
    <header class="h-20 bg-white border-b flex flex-wrap items-center justify-between px-4 sm:px-8 sticky top-0 z-10 gap-4">
      <div class="flex items-center gap-4">
        <h1 class="font-black text-xl sm:text-2xl uppercase tracking-tighter">Inventory</h1>
        <div class="h-6 w-px bg-slate-200 hidden sm:block"></div>
        <p class="text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest hidden sm:block">Catalog Management</p>
      </div>
      <button 
        id="add-product-btn"
        class="w-full sm:w-auto bg-slate-900 text-white px-6 py-2.5 rounded-xl font-black text-xs uppercase tracking-widest hover:bg-slate-800 transition-all shadow-xl active:scale-95"
      >
        + Add New Product
      </button>
    </header>

    <div class="p-4 sm:p-12 max-w-7xl mx-auto space-y-12">
      <div class="bg-white rounded-[2rem] sm:rounded-[2.5rem] border border-slate-100 shadow-sm overflow-x-auto no-scrollbar">
        <table class="w-full text-sm">
          <thead class="bg-slate-50/50 border-b border-slate-100">
            <tr>
              <th class="p-6 text-left font-black text-slate-500 uppercase tracking-widest text-[10px]">Product</th>
              <th class="p-6 text-left font-black text-slate-500 uppercase tracking-widest text-[10px] hidden md:table-cell">Category</th>
              <th class="p-6 text-left font-black text-slate-500 uppercase tracking-widest text-[10px]">Price</th>
              <th class="p-6 text-left font-black text-slate-500 uppercase tracking-widest text-[10px] hidden sm:table-cell">Stock</th>
              <th class="p-6 text-left font-black text-slate-500 uppercase tracking-widest text-[10px]">Status</th>
              <th class="p-6 text-right font-black text-slate-500 uppercase tracking-widest text-[10px]">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-50">
            {products.map((product: any) => (
              <tr class="hover:bg-slate-50/50 transition-colors group">
                <td class="p-6 min-w-[200px]">
                  <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center font-black text-slate-400 text-lg shadow-inner uppercase italic flex-shrink-0">
                      {product.name.charAt(0)}
                    </div>
                    <div>
                        <p class="font-black text-slate-900 text-lg leading-tight">{product.name}</p>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-tighter md:hidden">{product.category}</p>
                    </div>
                  </div>
                </td>
                <td class="p-6 hidden md:table-cell">
                  <span class="px-3 py-1 bg-slate-50 text-[10px] font-black text-slate-500 rounded-full border border-slate-100 uppercase tracking-widest">
                    {product.category}
                  </span>
                </td>
                <td class="p-6 font-black text-slate-900 whitespace-nowrap">{formatCurrency(product.price)}</td>
                <td class="p-6 hidden sm:table-cell">
                  <span class={cn(
                    "px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border",
                    product.stock < 10 ? "bg-red-50 text-red-700 border-red-100" : "bg-slate-100 text-slate-600 border-slate-200"
                  )}>
                    {product.stock} Units
                  </span>
                </td>
                <td class="p-6">
                  <button 
                    onclick={`toggleProduct('${product.id}', ${!product.active})`}
                    class="flex items-center gap-2 group/btn"
                  >
                    <div class={cn("w-2.5 h-2.5 rounded-full transition-all", product.active ? "bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.4)]" : "bg-slate-300")}></div>
                    <span class={cn("text-[10px] font-black uppercase tracking-widest", product.active ? "text-green-700" : "text-slate-400")}>
                      {product.active ? 'On Sale' : 'Disabled'}
                    </span>
                  </button>
                </td>
                <td class="p-6 text-right whitespace-nowrap">
                  <div class="flex items-center justify-end gap-2">
                    <button 
                         onclick={`editProduct(${JSON.stringify(product)})`}
                         class="p-2.5 bg-indigo-50 text-indigo-600 rounded-xl hover:bg-indigo-600 hover:text-white transition-all"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                    </button>
                    <button 
                         onclick={`deleteProduct('${product.id}')`}
                         class="p-2.5 bg-red-50 text-red-600 rounded-xl hover:bg-red-600 hover:text-white transition-all"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Edit/Add Modal -->
    <div id="product-modal" class="fixed inset-0 z-50 hidden">
        <div class="absolute inset-0 bg-slate-950/40 backdrop-blur-sm"></div>
        <div class="absolute inset-y-0 right-0 w-full max-w-lg bg-white shadow-2xl p-6 sm:p-12 flex flex-col transform transition-transform duration-500 translate-x-full" id="modal-content">
          <div class="flex items-center justify-between mb-8">
            <div>
                <h2 id="modal-title" class="text-3xl font-black text-slate-900 uppercase tracking-tighter italic">New Product</h2>
                <p class="text-slate-400 font-bold text-xs uppercase tracking-widest mt-1">Configure item details</p>
            </div>
            <button id="close-modal" class="p-3 hover:bg-slate-100 rounded-2xl transition-colors font-black">✕</button>
          </div>

          <form id="product-form" class="space-y-6 flex-1 overflow-y-auto no-scrollbar pb-10">
            <input type="hidden" name="id" id="form-id" />
            
            <div class="space-y-2">
              <label class="text-[10px] font-black text-indigo-600 uppercase tracking-[0.2em] ml-1">Display Name</label>
              <input type="text" name="name" required class="flex h-14 w-full rounded-2xl border-2 border-slate-100 bg-slate-50 px-5 text-sm font-bold focus:border-indigo-500 focus:bg-white outline-none transition-all" placeholder="e.g. Iced Vanilla Latte" />
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-indigo-600 uppercase tracking-[0.2em] ml-1">Category</label>
                    <input type="text" name="category" list="category-list" required class="flex h-14 w-full rounded-2xl border-2 border-slate-100 bg-slate-50 px-5 text-sm font-bold focus:border-indigo-500 focus:bg-white outline-none transition-all" placeholder="Beverage" />
                    <datalist id="category-list">
                        {categories.map((c: any) => <option value={c} />)}
                    </datalist>
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-indigo-600 uppercase tracking-[0.2em] ml-1">Sale Price</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-xs font-bold text-slate-400 font-mono">Rp</span>
                        <input type="number" name="price" required class="flex h-14 w-full rounded-2xl border-2 border-slate-100 bg-slate-50 pl-10 pr-5 text-sm font-black focus:border-indigo-500 focus:bg-white outline-none transition-all" />
                    </div>
                </div>
            </div>

            <div class="space-y-2">
                <label class="text-[10px] font-black text-indigo-600 uppercase tracking-[0.2em] ml-1">Initial Stock</label>
                <input type="number" name="stock" class="flex h-14 w-full rounded-2xl border-2 border-slate-100 bg-slate-50 px-5 text-sm font-bold focus:border-indigo-500 focus:bg-white outline-none transition-all" placeholder="0" />
            </div>

            <div class="pt-10 sticky bottom-0 bg-white">
              <button 
                type="submit" 
                class="w-full h-16 bg-slate-900 text-white rounded-2xl font-black uppercase tracking-widest text-sm hover:bg-slate-800 transition-all shadow-2xl hover:translate-y-[-2px]"
              >
                Sync with Inventory
              </button>
            </div>
          </form>
        </div>
      </div>
  </main>
</Layout>

<script is:inline>
  const modal = document.getElementById('product-modal');
  const modalContent = document.getElementById('modal-content');
  const form = document.getElementById('product-form');
  const modalTitle = document.getElementById('modal-title');

  function openModal(editing = false) {
    modal.classList.remove('hidden');
    modalTitle.textContent = editing ? 'Edit Product' : 'New Product';
    setTimeout(() => {
      modalContent.classList.remove('translate-x-full');
      modalContent.classList.add('translate-x-0');
    }, 10);
  }

  function closeModal() {
    modalContent.classList.remove('translate-x-0');
    modalContent.classList.add('translate-x-full');
    setTimeout(() => {
      modal.classList.add('hidden');
      form.reset();
      document.getElementById('form-id').value = '';
    }, 500);
  }

  document.getElementById('add-product-btn')?.addEventListener('click', () => openModal(false));
  document.getElementById('close-modal')?.addEventListener('click', closeModal);

  window.editProduct = (p) => {
    document.getElementById('form-id').value = p.id;
    form.name.value = p.name;
    form.category.value = p.category;
    form.price.value = p.price;
    form.stock.value = p.stock;
    openModal(true);
  };

  window.toggleProduct = async (id, active) => {
    if (!confirm(`Are you sure you want to ${active ? 'enable' : 'disable'} this product?`)) return;
    const res = await fetch('/api/products', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, active })
    });
    if (res.ok) window.location.reload();
  };

  window.deleteProduct = async (id) => {
    if (!confirm('EXTREME CAUTION: Delete this product permanently? This cannot be undone.')) return;
    const res = await fetch('/api/products', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id })
    });
    if (res.ok) window.location.reload();
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form).entries());
    const isEdit = !!data.id;

    const res = await fetch('/api/products', {
        method: isEdit ? 'PATCH' : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    });

    if (res.ok) window.location.reload();
    else {
        const err = await res.json();
        alert(err.message);
    }
  });
</script>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
</style>
