---
import Layout from '../../layouts/Layout.astro';
import { eq, desc } from 'drizzle-orm';
import * as schema from '../../db/schema';
import { cn, formatCurrency } from '../../lib/utils';

const { session, db } = Astro.locals;

if (session?.role !== 'super_admin') return Astro.redirect('/login');

const logs = await db.select({
  id: schema.transactions.id,
  invoiceNumber: schema.transactions.invoiceNumber,
  total: schema.transactions.total,
  createdAt: schema.transactions.createdAt,
  tenantName: schema.tenants.name,
  cashierName: schema.users.name,
})
.from(schema.transactions)
.leftJoin(schema.tenants, eq(schema.transactions.tenantId, schema.tenants.id))
.leftJoin(schema.users, eq(schema.transactions.cashierId, schema.users.id))
.orderBy(desc(schema.transactions.createdAt))
.limit(100);
---

<Layout title="System Logs | CoPos">
  <div class="flex flex-col md:flex-row h-screen bg-slate-900 overflow-hidden">
    <!-- Super Admin Header (Mobile) -->
    <header class="md:hidden flex items-center justify-between p-4 border-b border-white/10 shrink-0">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center font-black text-white italic text-xs">CP</div>
        <h1 class="text-white font-black text-xl tracking-tighter uppercase font-display">CoPos Admin</h1>
      </div>
      <button id="admin-menu-btn" class="text-white p-2">
         <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
    </header>

    <!-- Super Admin Sidebar -->
    <aside id="admin-sidebar" class="fixed md:static inset-y-0 left-0 z-50 w-72 bg-slate-900 border-r border-white/10 flex flex-col p-6 space-y-8 shrink-0 transform -translate-x-full md:translate-x-0 transition-transform duration-300">
      <div class="flex items-center justify-between px-2">
        <div class="flex items-center gap-3 hidden md:flex">
          <div class="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center font-black text-white italic">CP</div>
          <h1 class="text-white font-black text-2xl tracking-tighter uppercase font-display">CoPos Admin</h1>
        </div>
        <button id="admin-close-btn" class="md:hidden text-white p-2 absolute right-4 top-4">✕</button>
      </div>
      
      <nav class="flex-1 space-y-2 mt-8 md:mt-0">
        <a href="/super-admin" class="flex items-center gap-3 px-4 py-3 text-white/50 hover:text-white hover:bg-white/5 rounded-xl font-medium transition-all">
          <span class="text-xl">🏢</span> Tenants
        </a>
        <a href="/super-admin/users" class="flex items-center gap-3 px-4 py-3 text-white/50 hover:text-white hover:bg-white/5 rounded-xl font-medium transition-all">
          <span class="text-xl">👥</span> Global Users
        </a>
        <a href="/super-admin/logs" class="flex items-center gap-3 px-4 py-3 bg-white/10 text-white rounded-xl font-bold transition-all border border-white/10 shadow-lg">
          <span class="text-xl">🧾</span> System Logs
        </a>
      </nav>

      <div class="pt-6 border-t border-white/10">
        <a href="/logout" class="flex items-center gap-3 px-4 py-2 text-red-400 hover:text-red-300 transition-colors font-medium">
          <span class="text-xl">🚪</span> Logout
        </a>
      </div>
    </aside>

    <!-- Main Panel -->
    <main class="flex-1 overflow-y-auto bg-slate-50 md:rounded-tl-[3rem] mt-0 md:mt-4 md:ml-[-2rem] p-4 sm:p-8 md:p-12 shadow-2xl relative w-full overflow-x-hidden">
      <div class="max-w-6xl mx-auto space-y-8">
        <div class="flex items-center justify-between">
          <div class="space-y-1">
            <h1 class="text-3xl md:text-4xl font-black text-slate-900 tracking-tight">System Logs</h1>
            <p class="text-sm md:text-base text-slate-500 font-medium">Real-time global transaction monitoring across all tenants</p>
          </div>
        </div>

        <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-slate-50 border-b">
              <tr>
                <th class="p-6 text-left font-bold text-slate-500 uppercase tracking-wider">Time</th>
                <th class="p-6 text-left font-bold text-slate-500 uppercase tracking-wider">Tenant</th>
                <th class="p-6 text-left font-bold text-slate-500 uppercase tracking-wider">Invoice</th>
                <th class="p-6 text-left font-bold text-slate-500 uppercase tracking-wider">Cashier</th>
                <th class="p-6 text-right font-bold text-slate-500 uppercase tracking-wider">Amount</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
              {logs.length > 0 ? logs.map((log: any) => (
                <tr class="hover:bg-slate-50/50 transition-colors">
                  <td class="p-6 font-medium text-slate-500">
                    {log.createdAt ? new Date(log.createdAt).toLocaleString() : '-'}
                  </td>
                  <td class="p-6">
                    <span class="font-bold text-slate-700 bg-slate-100 px-3 py-1 rounded-lg">{log.tenantName}</span>
                  </td>
                  <td class="p-6 font-mono font-bold text-indigo-600">
                    {log.invoiceNumber}
                  </td>
                  <td class="p-6 text-slate-600 font-medium">
                    {log.cashierName}
                  </td>
                  <td class="p-6 text-right font-black text-slate-900">
                    {formatCurrency(log.total)}
                  </td>
                </tr>
              )) : (
                <tr>
                  <td colspan="5" class="p-12 text-center text-slate-400 font-medium">
                    No transactions found in the system yet.
                  </td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</Layout>

<script is:inline>
  const adminSidebar = document.getElementById('admin-sidebar');
  document.getElementById('admin-menu-btn')?.addEventListener('click', () => {
    adminSidebar.classList.remove('-translate-x-full');
  });
  document.getElementById('admin-close-btn')?.addEventListener('click', () => {
    adminSidebar.classList.add('-translate-x-full');
  });
</script>
