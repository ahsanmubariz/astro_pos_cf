---
import Layout from '../../layouts/Layout.astro';
import { eq } from 'drizzle-orm';
import * as schema from '../../db/schema';
import { cn } from '../../lib/utils';

const { session, db } = Astro.locals;

if (session?.role !== 'super_admin') return Astro.redirect('/login');

const users = await db.select({
  id: schema.users.id,
  name: schema.users.name,
  username: schema.users.username,
  role: schema.users.role,
  active: schema.users.active,
  createdAt: schema.users.createdAt,
  tenantName: schema.tenants.name
})
.from(schema.users)
.leftJoin(schema.tenants, eq(schema.users.tenantId, schema.tenants.id));

const tenants = await db.select().from(schema.tenants);
---

<Layout title="Global Users | CoPos">
  <div class="flex flex-col md:flex-row h-screen bg-slate-900 overflow-hidden">
    <!-- Super Admin Header (Mobile) -->
    <header class="md:hidden flex items-center justify-between p-4 border-b border-white/10 shrink-0">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center font-black text-white italic text-xs">CP</div>
        <h1 class="text-white font-black text-xl tracking-tighter uppercase font-display">CoPos Admin</h1>
      </div>
      <button id="admin-menu-btn" class="text-white p-2">
         <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
    </header>

    <!-- Super Admin Sidebar -->
    <aside id="admin-sidebar" class="fixed md:static inset-y-0 left-0 z-50 w-72 bg-slate-900 border-r border-white/10 flex flex-col p-6 space-y-8 shrink-0 transform -translate-x-full md:translate-x-0 transition-transform duration-300">
      <div class="flex items-center justify-between px-2">
        <div class="flex items-center gap-3 hidden md:flex">
          <div class="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center font-black text-white italic">CP</div>
          <h1 class="text-white font-black text-2xl tracking-tighter uppercase font-display">CoPos Admin</h1>
        </div>
        <button id="admin-close-btn" class="md:hidden text-white p-2 absolute right-4 top-4">✕</button>
      </div>
      
      <nav class="flex-1 space-y-2 mt-8 md:mt-0">
        <a href="/super-admin" class="flex items-center gap-3 px-4 py-3 text-white/50 hover:text-white hover:bg-white/5 rounded-xl font-medium transition-all">
          <span class="text-xl">🏢</span> Tenants
        </a>
        <a href="/super-admin/users" class="flex items-center gap-3 px-4 py-3 bg-white/10 text-white rounded-xl font-bold transition-all border border-white/10 shadow-lg">
          <span class="text-xl">👥</span> Global Users
        </a>
        <a href="/super-admin/logs" class="flex items-center gap-3 px-4 py-3 text-white/50 hover:text-white hover:bg-white/5 rounded-xl font-medium transition-all">
          <span class="text-xl">🧾</span> System Logs
        </a>
      </nav>

      <div class="pt-6 border-t border-white/10">
        <a href="/logout" class="flex items-center gap-3 px-4 py-2 text-red-400 hover:text-red-300 transition-colors font-medium">
          <span class="text-xl">🚪</span> Logout
        </a>
      </div>
    </aside>

    <!-- Main Panel -->
    <main class="flex-1 overflow-y-auto bg-slate-50 md:rounded-tl-[3rem] mt-0 md:mt-4 md:ml-[-2rem] p-4 sm:p-8 md:p-12 shadow-2xl relative w-full overflow-x-hidden">
      <div class="max-w-6xl mx-auto space-y-8">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
          <div class="space-y-1">
            <h1 class="text-3xl md:text-4xl font-black text-slate-900 tracking-tight">Global Users</h1>
            <p class="text-sm md:text-base text-slate-500 font-medium">Manage administrators and cashiers across all business units</p>
          </div>
          <button 
            id="open-modal"
            class="w-full sm:w-auto bg-indigo-600 text-white px-6 py-3 rounded-2xl font-bold hover:bg-indigo-700 transition-all shadow-lg hover:translate-y-[-2px] active:scale-95"
          >
            + Create New User
          </button>
        </div>

        <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
          <table class="w-full text-sm">
            <thead class="bg-slate-50 border-b">
              <tr>
                <th class="p-6 text-left font-bold text-slate-500 uppercase tracking-wider">User</th>
                <th class="p-6 text-left font-bold text-slate-500 uppercase tracking-wider">Role</th>
                <th class="p-6 text-left font-bold text-slate-500 uppercase tracking-wider">Tenant</th>
                <th class="p-6 text-left font-bold text-slate-500 uppercase tracking-wider">Status</th>
                <th class="p-6 text-right font-bold text-slate-500 uppercase tracking-wider">Created</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
              {users.map((user: any) => (
                <tr class="hover:bg-slate-50/50 transition-colors">
                  <td class="p-6">
                    <div class="flex items-center gap-3">
                      <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center font-bold text-slate-400">
                        {user.name.charAt(0)}
                      </div>
                      <div>
                        <p class="font-bold text-slate-900">{user.name}</p>
                        <p class="text-xs text-slate-400 font-medium">@{user.username}</p>
                      </div>
                    </div>
                  </td>
                  <td class="p-6">
                    <span class={cn(
                      "px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider border",
                      user.role === 'super_admin' ? "bg-indigo-50 text-indigo-700 border-indigo-100" :
                      user.role === 'tenant_admin' ? "bg-blue-50 text-blue-700 border-blue-100" :
                      "bg-emerald-50 text-emerald-700 border-emerald-100"
                    )}>
                      {user.role.replace('_', ' ')}
                    </span>
                  </td>
                  <td class="p-6">
                    <span class="font-bold text-slate-600">{user.tenantName || 'Global Platform'}</span>
                  </td>
                  <td class="p-6">
                    <div class="flex items-center gap-1.5">
                      <div class={cn("w-2 h-2 rounded-full", user.active ? "bg-green-500" : "bg-slate-300")}></div>
                      <span class={cn("text-xs font-bold", user.active ? "text-green-700" : "text-slate-400")}>
                        {user.active ? 'Active' : 'Inactive'}
                      </span>
                    </div>
                  </td>
                  <td class="p-6 text-right font-medium text-slate-400">
                    {user.createdAt ? user.createdAt.toLocaleDateString() : '-'}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Create User Modal -->
      <div id="user-modal" class="fixed inset-0 z-50 hidden">
        <div class="absolute inset-0 bg-slate-950/40 backdrop-blur-sm"></div>
        <div class="absolute inset-y-0 right-0 w-full max-w-lg bg-white shadow-2xl p-6 sm:p-10 flex flex-col transform transition-transform duration-300 translate-x-full" id="modal-content">
          <div class="flex items-center justify-between mb-8 shrink-0">
            <h2 class="text-2xl sm:text-3xl font-black text-slate-900">New User</h2>
            <button id="close-modal" class="p-2 hover:bg-slate-100 rounded-full transition-colors text-lg font-black">✕</button>
          </div>

          <form id="add-user-form" class="space-y-6 flex-1 overflow-y-auto no-scrollbar pb-10">
            <div class="space-y-4">
              <h3 class="text-xs font-bold text-indigo-600 uppercase tracking-widest">Account Details</h3>
              <div class="space-y-1">
                <label class="text-sm font-bold text-slate-700">Full Name</label>
                <input type="text" name="name" required class="flex h-12 w-full rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-all font-medium" />
              </div>
              <div class="space-y-1">
                <label class="text-sm font-bold text-slate-700">Username</label>
                <input type="text" name="username" required class="flex h-12 w-full rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-all font-medium" />
              </div>
              <div class="space-y-1">
                <label class="text-sm font-bold text-slate-700">Login PIN</label>
                <input type="password" name="pin" required maxlength="6" pattern="[0-9]*" inputmode="numeric" class="flex h-12 w-full rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-all text-center tracking-widest font-black" placeholder="••••••" />
              </div>
            </div>

            <div class="space-y-4 pt-4">
              <h3 class="text-xs font-bold text-indigo-600 uppercase tracking-widest">Permissions</h3>
              <div class="space-y-1">
                <label class="text-sm font-bold text-slate-700">Role</label>
                <select name="role" required class="flex h-12 w-full rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-all font-bold appearance-none bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20fill%3D%22none%22%20viewBox%3D%220%200%2024%2024%22%20stroke%3D%22currentColor%22%3E%3Cpath%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%20stroke-width%3D%222%22%20d%3D%22M19%209l-7%207-7-7%22%20%2F%3E%3C%2Fsvg%3E')] bg-[length:1.25rem_1.25rem] bg-[right_1rem_center] bg-no-repeat">
                  <option value="cashier">Cashier</option>
                  <option value="tenant_admin">Tenant Admin</option>
                  <option value="super_admin">Global Super Admin</option>
                </select>
              </div>
              <div class="space-y-1" id="tenant-select-container">
                <label class="text-sm font-bold text-slate-700">Assign to Tenant</label>
                <select name="tenantId" class="flex h-12 w-full rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-all font-bold appearance-none bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20fill%3D%22none%22%20viewBox%3D%220%200%2024%2024%22%20stroke%3D%22currentColor%22%3E%3Cpath%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%20stroke-width%3D%222%22%20d%3D%22M19%209l-7%207-7-7%22%20%2F%3E%3C%2Fsvg%3E')] bg-[length:1.25rem_1.25rem] bg-[right_1rem_center] bg-no-repeat">
                  <option value="">Global (No Tenant)</option>
                  {tenants.map((t: any) => (
                    <option value={t.id}>{t.name}</option>
                  ))}
                </select>
              </div>
            </div>

            <div class="pt-8 sticky bottom-0 bg-white mt-auto">
              <button 
                type="submit" 
                class="w-full h-14 bg-indigo-600 text-white rounded-2xl font-bold text-lg hover:bg-indigo-700 transition-all shadow-xl hover:translate-y-[-2px] active:scale-[0.98]"
              >
                Create User
              </button>
            </div>
          </form>
        </div>
      </div>
    </main>
  </div>
</Layout>

<script is:inline>
  const adminSidebar = document.getElementById('admin-sidebar');
  document.getElementById('admin-menu-btn')?.addEventListener('click', () => {
    adminSidebar.classList.remove('-translate-x-full');
  });
  document.getElementById('admin-close-btn')?.addEventListener('click', () => {
    adminSidebar.classList.add('-translate-x-full');
  });

  const modal = document.getElementById('user-modal');
  const modalContent = document.getElementById('modal-content');
  const openBtn = document.getElementById('open-modal');
  const closeBtn = document.getElementById('close-modal');
  const form = document.getElementById('add-user-form');
  const roleSelect = form.querySelector('select[name="role"]');
  const tenantContainer = document.getElementById('tenant-select-container');

  function openModal() {
    modal.classList.remove('hidden');
    setTimeout(() => {
      modalContent.classList.remove('translate-x-full');
      modalContent.classList.add('translate-x-0');
    }, 10);
  }

  function closeModal() {
    modalContent.classList.remove('translate-x-0');
    modalContent.classList.add('translate-x-full');
    setTimeout(() => {
      modal.classList.add('hidden');
    }, 300);
  }

  roleSelect?.addEventListener('change', (e) => {
    if (e.target.value === 'super_admin') {
      tenantContainer.classList.add('opacity-50', 'pointer-events-none');
      form.querySelector('select[name="tenantId"]').value = "";
    } else {
      tenantContainer.classList.remove('opacity-50', 'pointer-events-none');
    }
  });

  openBtn?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal.children[0]) closeModal();
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = form.querySelector('button[type="submit"]');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Creating...';

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const res = await fetch('/api/users', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        window.location.reload();
      } else {
        const err = await res.json();
        alert(err.message || 'Failed to create user');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Create User';
      }
    } catch (err) {
      alert('An expected error occurred');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Create User';
    }
  });
</script>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
</style>
