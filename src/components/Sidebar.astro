---
import { cn } from '../lib/utils';

interface Props {
  tenantSlug: string;
  tenantName: string;
  currentPath: string;
  role: string;
}

const { tenantSlug, tenantName, currentPath, role } = Astro.props;

const navItems = [
  { 
    name: 'Dashboard', 
    href: `/${tenantSlug}/dashboard`, 
    icon: '📊',
    roles: ['super_admin', 'tenant_admin']
  },
  { 
    name: 'POS', 
    href: `/${tenantSlug}/pos`, 
    icon: '🖥️',
    roles: ['super_admin', 'tenant_admin', 'cashier']
  },
  { 
    name: 'Orders', 
    href: `/${tenantSlug}/orders`, 
    icon: '🧾',
    roles: ['super_admin', 'tenant_admin', 'cashier']
  },
  { 
    name: 'Shift', 
    href: `/${tenantSlug}/shift`, 
    icon: '💰',
    roles: ['super_admin', 'tenant_admin', 'cashier']
  },
  { 
    name: 'Products', 
    href: `/${tenantSlug}/admin/products`, 
    icon: '📦',
    roles: ['super_admin', 'tenant_admin']
  },
  { 
    name: 'Users', 
    href: `/${tenantSlug}/admin/users`, 
    icon: '👥',
    roles: ['super_admin', 'tenant_admin']
  },
  { 
    name: 'Settings', 
    href: `/${tenantSlug}/admin/settings`, 
    icon: '⚙️',
    roles: ['super_admin', 'tenant_admin']
  },
].filter(item => item.roles.includes(role));
---

<aside class="w-full h-full border-r border-slate-200 bg-white flex flex-col shrink-0">
  <div class="p-8 border-b border-slate-100 mb-4">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 bg-slate-900 rounded-xl flex items-center justify-center font-black text-white italic">CP</div>
      <div>
        <h2 class="font-black text-slate-900 tracking-tighter uppercase whitespace-nowrap overflow-hidden text-ellipsis max-w-[140px]">{tenantName}</h2>
        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">{role.replace('_', ' ')}</p>
      </div>
    </div>
  </div>
  
  <nav class="flex-1 p-4 space-y-1.5 overflow-y-auto no-scrollbar">
    {navItems.map(item => (
      <a 
        href={item.href}
        class={cn(
          "flex items-center gap-3 px-4 py-3.5 text-sm font-bold rounded-2xl transition-all duration-200 group",
          currentPath === item.href || (item.href !== `/${tenantSlug}/dashboard` && currentPath.startsWith(item.href))
            ? "bg-slate-900 text-white shadow-lg shadow-slate-900/20" 
            : "text-slate-500 hover:bg-slate-50 hover:text-slate-900"
        )}
      >
        <span class="text-xl group-hover:scale-110 transition-transform">{item.icon}</span>
        {item.name}
      </a>
    ))}
  </nav>

  <div class="p-4 mt-auto border-t border-slate-50">
    <a href="/logout" class="flex items-center gap-3 px-4 py-3 text-sm font-bold text-red-500 hover:bg-red-50 rounded-2xl transition-all">
      <span class="text-xl">🚪</span> Logout
    </a>
  </div>
</aside>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
</style>
